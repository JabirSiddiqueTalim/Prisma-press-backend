model User{
  id           String    @id @default(uuid())
  name         String    @db.VarChar(255)
  email        String    @unique
  password     String
  activeStatus String    @default("Active")
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  profileId    Profile?
  @@map("users")
}
